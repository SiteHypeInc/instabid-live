# LiveKit Cloud (server-side, for minting the bot's join token)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Gemini Live (Google AI Studio key with Gemini 2.0 access)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Optional: Rails pricing API base. Used by the agent's tool calls.
RAILS_PRICING_API_URL=
RAILS_PRICING_API_KEY=

# Bind address for the spawn endpoint (POST /spawn { room })
PORT=8787
