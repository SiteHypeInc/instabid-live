ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_HARD=claude-opus-4-7

# Persistence target. Estimates POST to RAILS_API_URL/api/v1/estimates when
# RAILS_API_URL is set (or ESTIMATE_SINK=rails); otherwise they are written
# to LOCAL_SINK_DIR (defaults to estimate-generator/local-sink/).
RAILS_API_URL=
RAILS_API_KEY=
ESTIMATE_SINK=
LOCAL_SINK_DIR=

PORT=8788
