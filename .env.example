# LiveKit Cloud credentials (server-side, used by /api/livekit/token)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# WebSocket URL of the LiveKit Cloud project, e.g. wss://instabid.livekit.cloud
# Exposed to the browser so the client SDK can connect.
NEXT_PUBLIC_LIVEKIT_URL=

# Optional shared secret for the link-mint flow. If set, /api/livekit/token requires
# a matching `?key=` (or Authorization: Bearer) before issuing tokens. Leave empty
# in dev; set in Vercel for prod previews.
LIVEKIT_LINK_SECRET=
